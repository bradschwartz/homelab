---
write-kubeconfig-mode: "0644"
tls-san:
{% if tailscale_ip is defined and tailscale_ip | length > 0 %}
  - {{ tailscale_ip }}
{% endif %}
  - raspberrypi
  - {{ ansible_host }}
disable:
  - traefik
kube-controller-manager-arg:
  - "bind-address=0.0.0.0"
kube-scheduler-arg:
  - "bind-address=0.0.0.0"
